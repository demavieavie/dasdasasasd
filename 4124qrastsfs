local TemporaryFolder = workspace:WaitForChild("Temporary")

local function getRemote()
    local sharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
    local packet = sharedModules and sharedModules:FindFirstChild("Packet")
    return packet and packet:FindFirstChild("RemoteEvent")
end

local function getAllToolEggData()
    local eggList = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")

    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local eggAttribute = item:GetAttribute("Egg")
                if tostring(eggAttribute) == "Rainbow Egg" then
                    table.insert(eggList, {
                        name = "Rainbow Egg",
                        count = math.max(1, tonumber(item:GetAttribute("Count")) or 1)
                    })
                end
            end
        end
    end
    return eggList
end

local function sendWebhook(petName, petRarity, petSize, petType)
    local requestFunc = (syn and syn.request)
        or http_request
        or request
        or (fluxus and fluxus.request)
        or (http and http.request)

    if type(requestFunc) ~= "function" then
        warn("Webhook request function not available.")
        return
    end

    local details = string.format(
        "King Hamka dapet pet: %s\nRarity: %s\nPetSize: %s\nPetType: %s",
        tostring(petName),
        tostring(petRarity ~= "" and petRarity or "-"),
        tostring(petSize ~= "" and petSize or "-"),
        tostring(petType ~= "" and petType or "-")
    )

    pcall(function()
        requestFunc({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode({
                username = "King Hamka",
                content = details
            })
        })
    end)
end

local function normalizeName(value)
    return tostring(value or ""):lower():gsub("[^%w]", "")
end

local function getExistingTools()
    local existing = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                existing[item] = true
            end
        end
    end
    return existing
end

-- Valid targets:
-- 1. Any Rainbow pet whose rarity is Super.
-- 2. Rainbow Bear.
-- 3. Rainbow Raccoon (kept explicit even though Raccoon is currently Super).
local function checkPetData(existingTools)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil end

    for _, item in ipairs(backpack:GetChildren()) do
        if item:IsA("Tool") and not existingTools[item] then
            -- Lookup internal pet rarity from game module data
            local moduleKey = string.gsub(item.Name, "%s+", "")
            local petConfig = PetData[moduleKey]
            local petRarity = petConfig and petConfig.Rarity and tostring(petConfig.Rarity) or ""

            -- Lookup attributes
            local petSizeAttribute = item:GetAttribute("PetSize")
            local petSize = petSizeAttribute and tostring(petSizeAttribute) or ""
            local petTypeAttribute = item:GetAttribute("PetType")
            local petType = petTypeAttribute and tostring(petTypeAttribute) or ""

            local rarity = petRarity:lower()
            local petTypeLower = petType:lower()
            local petName = normalizeName(item.Name)

            local isRainbow = petTypeLower == "rainbow"
            local isRainbowSuper = isRainbow and rarity == "super"
            local isNamedRainbowTarget = isRainbow
                and (petName == "bear" or petName == "raccoon")

            if isRainbowSuper or isNamedRainbowTarget then
                return {
                    name = item.Name,
                    rarity = petRarity,
                    size = petSize,
                    petType = petType
                }
            end
        end
    end
    return nil
end

local function waitForTarget(existingTools, timeout)
    local deadline = os.clock() + timeout
    repeat
        local target = checkPetData(existingTools)
        if target then return target end
        task.wait(0.1)
    until os.clock() >= deadline
    return nil
end

local function stopRollback(packetRemote)
    rollbackStopped = true
    reconnecting = false

    pcall(function()
        packetRemote:FireServer(54, "")
        packetRemote:FireServer(54, string.char(0x20))
        packetRemote:FireServer(54)
        packetRemote:FireServer(20, "")
    end)
end

local function main()
    local packetRemote = getRemote()
    if not packetRemote then
        warn("Packet RemoteEvent not found! Rejoining to retry...")
        reconnect()
        return
    end

    local eggsFound = getAllToolEggData()
    if #eggsFound == 0 then
        warn("Rainbow Egg not found. Rejoining to retry...")
        reconnect()
        return
    end

    local existingTools = getExistingTools()
    local payload = string.char(0x3A, 0xF7)
    packetRemote:FireServer(payload)
    packetRemote:FireServer(54, "\xEF\xBF")
    packetRemote:FireServer(54, ":\xF7")

    for _, eggData in ipairs(eggsFound) do
        for i = 1, eggData.count do
            packetRemote:FireServer(
                buffer.fromstring("\x8E\x00\x11\n" .. eggData.name)
            )
        end
    end

    task.wait(3)
    local animationDeadline = os.clock() + 30
    while #TemporaryFolder:GetChildren() > 0 and os.clock() < animationDeadline do
        task.wait(0.1)
    end

    -- Only evaluate newly-created tools from this hatch.
    local target = waitForTarget(existingTools, 5)

    if not target then
        print("No target criteria met. Triggering safe auto-rejoin...")
        reconnect()
    else
        -- Disable every reconnect path before doing network/webhook work.
        stopRollback(packetRemote)
        print(string.format(
            "Target Saved! Pet: %s | Rarity: %s | Size: '%s' | Type: '%s'",
            target.name,
            target.rarity,
            target.size,
            target.petType
        ))
        sendWebhook(target.name, target.rarity, target.size, target.petType)
        print("Rollback and auto-rejoin stopped.")
    end
end

local ok, err = xpcall(main, debug.traceback)
if not ok then
    warn("Main loop failed: " .. tostring(err))
    reconnect()
end
