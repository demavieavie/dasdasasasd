-- ==========================================
-- 1. PERSISTENCE & AUTO-RECONNECT MODULE
-- ==========================================
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer or Players.PlayerAdded:Wait()
local IGNORED_KEYWORDS = { "kg", "matching", "matched", "bye" }

-- Queue this script to automatically re-run upon joining the next server
local queueOnTeleport = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
if type(queueOnTeleport) == "function" then
    pcall(function()
        queueOnTeleport([[
            loadstring(game:HttpGet("YOUR_SCRIPT_URL_HERE_IF_USING_LOADSTRING"))()
            -- Or paste this entire script inside if running via local executor file configs
        ]])
    end)
end

local function getPromptText(prompt)
    local parts = {}
    local ok, descendants = pcall(function() return prompt:GetDescendants() end)
    if not ok or not descendants then return "" end

    for _, obj in ipairs(descendants) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            table.insert(parts, tostring(obj.Text or ""):lower())
        end
    end
    return table.concat(parts, " ")
end

local function promptHasIgnoredKickText(prompt)
    local text = getPromptText(prompt)
    for _, keyword in ipairs(IGNORED_KEYWORDS) do
        if keyword ~= "" and text:find(keyword:lower(), 1, true) then
            return true
        end
    end
    return false
end

local reconnecting = false
local function reconnect()
    if reconnecting then return end
    reconnecting = true
    task.wait(1.5)

    if LocalPlayer then
        local success = false
        if game.JobId and game.JobId ~= "" then
            success = pcall(function()
                TeleportService:Teleport(game.PlaceId, LocalPlayer)
            end)
        end
        if not success then
            pcall(function()
                TeleportService:Teleport(game.PlaceId, LocalPlayer)
            end)
        end
    end
    reconnecting = false
end

-- Monitor CoreGui for Roblox Disconnect / Error Prompts
local robloxPromptGui = CoreGui:WaitForChild("RobloxPromptGui", 30)
local promptOverlay = robloxPromptGui and robloxPromptGui:WaitForChild("promptOverlay", 30)

if promptOverlay then
    local function checkPrompt(child)
        if child.Name == "ErrorPrompt" then
            task.defer(function()
                task.wait(0.3)
                if promptHasIgnoredKickText(child) then return end
                reconnect()
            end)
        end
    end
    promptOverlay.ChildAdded:Connect(checkPrompt)
    for _, child in ipairs(promptOverlay:GetChildren()) do
        checkPrompt(child)
    end
end

-- Fallback handler for transit errors
pcall(function()
    TeleportService.TeleportInitFailed:Connect(function()
        task.wait(3)
        reconnect()
    end)
end)

-- ==========================================
-- 2. MAIN GAMEPLAY SCRIPT LOGIC
-- ==========================================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInputManager = game:GetService("VirtualInputManager")

-- Requiring the internal game data modules
local PetData = require(ReplicatedStorage.SharedData.PetData)

local menu = game:GetService("Workspace"):FindFirstChild("LoadingScreenMenu")

if menu then
    local gui = menu:WaitForChild("LoadingGui", 2)
    local variantFrame = gui and gui:WaitForChild("Variant1Frame", 2)
    local innerFrame = variantFrame and variantFrame:WaitForChild("InnerFrame", 2)
    local counter = innerFrame and innerFrame:WaitForChild("CounterTxt", 2)

    if counter then
        repeat
            task.wait(0.2)
        until counter.Text == "Fully Loaded!"
    end

    VirtualInputManager:SendMouseButtonEvent(100, 100, 0, true, game, 0)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(100, 100, 0, false, game, 0)

    if not LocalPlayer:GetAttribute("LoadingScreenDone") then
        LocalPlayer:GetAttributeChangedSignal("LoadingScreenDone"):Wait()
    end
end

local TemporaryFolder = workspace:WaitForChild("Temporary")

local function getRemote()
    local sharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
    local packet = sharedModules and sharedModules:FindFirstChild("Packet")
    return packet and packet:FindFirstChild("RemoteEvent")
end

local function getAllToolEggData()
    local eggList = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")

    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local eggAttribute = item:GetAttribute("Egg")
                if eggAttribute ~= nil then
                    table.insert(eggList, {
                        name = tostring(eggAttribute),
                        count = tonumber(item:GetAttribute("Count"))
                    })
                end
            end
        end
    end
    return eggList
end

-- Saves Secret pets automatically.
-- Saves Mythic/Super pets only if they have any PetSize or Rainbow type.
local function checkPetData()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return false end

    for _, item in ipairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            -- Lookup internal pet rarity from game module data
            local moduleKey = string.gsub(item.Name, "%s+", "")
            local petConfig = PetData[moduleKey]
            local petRarity = petConfig and petConfig.Rarity and tostring(petConfig.Rarity) or ""

            -- Lookup attributes
            local petSizeAttribute = item:GetAttribute("PetSize")
            local petSize = petSizeAttribute and tostring(petSizeAttribute) or ""
            local petTypeAttribute = item:GetAttribute("PetType")
            local petType = petTypeAttribute and tostring(petTypeAttribute) or ""

            local rarity = petRarity:lower()
            local size = petSize:lower()
            local petTypeLower = petType:lower()

            local isSecret = rarity == "secret"
            local isWantedRarity = rarity == "mythic" or rarity == "super"
            local hasWantedModifier = size ~= "" or petTypeLower == "rainbow"

            if isSecret or (isWantedRarity and hasWantedModifier) then
                print(string.format("Target Saved! Rarity: %s | Size: '%s' | Type: '%s'", petRarity, petSize, petType))
                return true
            end
        end
    end
    return false
end

local function main()
    local packetRemote = getRemote()
    if not packetRemote then
        warn("Packet RemoteEvent not found!")
        return
    end

    local eggsFound = getAllToolEggData()
    if #eggsFound == 0 then
        table.insert(eggsFound, {name = "Common Egg", count = 1})
    end

    local payload = string.char(0x3A, 0xF7)
    packetRemote:FireServer(payload)
    packetRemote:FireServer(54, "\xEF\xBF")
    packetRemote:FireServer(54, ":\xF7")

    for _, eggData in ipairs(eggsFound) do
        for i = 1, eggData.count do
            packetRemote:FireServer(
                buffer.fromstring("\x8E\x00\x11\n" .. eggData.name)
            )
        end
    end

    task.wait(3)
    while #TemporaryFolder:GetChildren() > 0 do
        task.wait(0.1)
    end

    -- Evaluate inventory against conditional rules
    local targetFound = checkPetData()

    if not targetFound then
        print("No target criteria met. Triggering safe auto-rejoin...")
        reconnect()
    else
        packetRemote:FireServer(54, "")
        packetRemote:FireServer(54, string.char(0x20))
        packetRemote:FireServer(54)
        packetRemote:FireServer(20, "")
        print("Target conditions met! Skipped auto-rejoin.")
    end
end

main()
