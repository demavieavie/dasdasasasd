local WEBHOOK_URL = "https://discord.com/api/webhooks/1524059522493317331/DzrGCyWCzLmhalRZTDWs6HD0YLyNdrsMG6ZeI5M6v1OmevKIS8Bv7Jm2axGKdC7SHnuf"

